# ──────────────────────────────────────────────
# 1. DISCORD BOT TOKEN
#    Get from: https://discord.com/developers/applications
#    → New Application → Bot → Reset Token → Copy
# ──────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# ──────────────────────────────────────────────
# 2. ANTHROPIC API KEY
#    Get from: https://console.anthropic.com/settings/keys
#    → Create Key → Copy
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ──────────────────────────────────────────────
# 3. PROJECT PATH (the folder Cursor has open)
#    This is where the bot writes files to.
#    Use forward slashes or escaped backslashes.
# ──────────────────────────────────────────────
PROJECT_PATH=C:/Users/defre/your-project-folder

# ──────────────────────────────────────────────
# 4. YOUR DISCORD USER ID (optional, for security)
#    Right-click your name in Discord → Copy User ID
#    (Enable Developer Mode in Discord settings first)
#    Leave blank to allow anyone in the server to use it.
# ──────────────────────────────────────────────
ALLOWED_USER_ID=
